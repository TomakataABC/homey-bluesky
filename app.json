{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "app.bsky",
  "version": "1.0.0",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "brandColor": "#1185FE",
  "platforms": [
    "local",
    "cloud"
  ],
  "name": {
    "en": "Bluesky",
    "cs": "Bluesky"
  },
  "description": {
    "en": "Post to your Bluesky network from Homey Flows.",
    "cs": "Publikujte do své sítě Bluesky pomocí Homey Flow."
  },
  "author": {
    "name": "Tomáš Pryl",
    "email": "t.pryl@seznam.cz"
  },
  "category": [
    "internet"
  ],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "flow": {
    "actions": [
      {
        "title": {
          "en": "Create post",
          "cs": "Vytvořit příspěvek"
        },
        "titleFormatted": {
          "en": "Create post with [[text]]",
          "cs": "Vytvořit příspěvek s textem [[text]]"
        },
        "hint": {
          "en": "Posts the supplied text through the selected Bluesky account.",
          "cs": "Odešle zadaný text přes vybraný účet Bluesky."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=bluesky-account"
          },
          {
            "type": "text",
            "name": "text",
            "title": {
              "en": "Post text",
              "cs": "Text příspěvku"
            },
            "placeholder": {
              "en": "What should be posted?",
              "cs": "Co se má zveřejnit?"
            }
          }
        ],
        "id": "create_post"
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "Bluesky account",
        "cs": "Účet Bluesky"
      },
      "platforms": [
        "local",
        "cloud"
      ],
      "class": "other",
      "capabilities": [],
      "images": {
        "small": "/drivers/bluesky-account/assets/images/small.png",
        "large": "/drivers/bluesky-account/assets/images/large.png",
        "xlarge": "/drivers/bluesky-account/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "login_credentials",
          "template": "login_credentials",
          "options": {
            "title": {
              "en": "Sign in to Bluesky",
              "cs": "Přihlásit se do Bluesky"
            },
            "usernameLabel": {
              "en": "Handle",
              "cs": "Handle"
            },
            "usernamePlaceholder": {
              "en": "alice.bsky.social",
              "cs": "alice.bsky.social"
            },
            "passwordLabel": {
              "en": "App password",
              "cs": "Heslo aplikace"
            },
            "passwordPlaceholder": {
              "en": "xxxx-xxxx-xxxx-xxxx",
              "cs": "xxxx-xxxx-xxxx-xxxx"
            }
          }
        },
        {
          "id": "list_devices",
          "template": "list_devices_singular",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "id": "bluesky-account"
    }
  ]
}